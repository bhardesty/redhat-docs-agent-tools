<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE concept PUBLIC "-//OASIS//DTD DITA Concept//EN" "concept.dtd">
<concept id="system-requirements">
  <title>System Requirements</title>
  <shortdesc>Review the hardware and software requirements before installing the product.</shortdesc>
  <conbody>
    <section>
      <title>Hardware Requirements</title>
      <simpletable>
        <sthead>
          <stentry>Component</stentry>
          <stentry>Minimum</stentry>
          <stentry>Recommended</stentry>
        </sthead>
        <strow>
          <stentry>CPU</stentry>
          <stentry>2 cores</stentry>
          <stentry>4 cores</stentry>
        </strow>
        <strow>
          <stentry>RAM</stentry>
          <stentry>4 GB</stentry>
          <stentry>8 GB</stentry>
        </strow>
        <strow>
          <stentry>Disk</stentry>
          <stentry>10 GB</stentry>
          <stentry>20 GB</stentry>
        </strow>
      </simpletable>
    </section>
    <section>
      <title>Software Requirements</title>
      <ul>
        <li>Linux kernel 5.0 or later</li>
        <li>glibc 2.31 or later</li>
        <li>Python 3.10 or later</li>
      </ul>
      <note type="important">
        <p>Windows and macOS are not supported in this release.</p>
      </note>
    </section>
  </conbody>
</concept>
