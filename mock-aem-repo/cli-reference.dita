<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE reference PUBLIC "-//OASIS//DTD DITA Reference//EN" "reference.dtd">
<reference id="cli-reference">
  <title>CLI Reference</title>
  <shortdesc>Command-line interface reference for the product.</shortdesc>
  <refbody>
    <section>
      <title>Global Options</title>
      <simpletable>
        <sthead>
          <stentry>Option</stentry>
          <stentry>Description</stentry>
          <stentry>Default</stentry>
        </sthead>
        <strow>
          <stentry><codeph>--verbose</codeph></stentry>
          <stentry>Enable verbose output</stentry>
          <stentry><codeph>false</codeph></stentry>
        </strow>
        <strow>
          <stentry><codeph>--config</codeph></stentry>
          <stentry>Path to configuration file</stentry>
          <stentry><codeph>~/.config/product/config.toml</codeph></stentry>
        </strow>
      </simpletable>
    </section>
    <section>
      <title>Commands</title>
      <dl>
        <dlentry>
          <dt><codeph>product init</codeph></dt>
          <dd>Initialize a new project in the current directory.</dd>
        </dlentry>
        <dlentry>
          <dt><codeph>product build</codeph></dt>
          <dd>Build the project artifacts.</dd>
        </dlentry>
        <dlentry>
          <dt><codeph>product deploy</codeph></dt>
          <dd>Deploy the project to the target environment.</dd>
        </dlentry>
      </dl>
    </section>
  </refbody>
</reference>
